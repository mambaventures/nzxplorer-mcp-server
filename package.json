{
  "name": "nzxplorer-mcp",
  "version": "1.3.0",
  "description": "MCP server for NZX (New Zealand Stock Exchange) financial data — governance scores, insider trades, stock prices, directors, financials, earnings, executive compensation, and 64,000+ company announcements",
  "type": "module",
  "bin": {
    "nzxplorer-mcp": "./build/index.js"
  },
  "main": "./build/index.js",
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nzx",
    "new-zealand",
    "stock-exchange",
    "finance",
    "governance",
    "insider-trades",
    "stock-prices",
    "directors",
    "announcements",
    "ai",
    "llm",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mambaventures/nzxplorer-mcp-server.git"
  },
  "homepage": "https://nzxplorer.co.nz/developers",
  "bugs": {
    "url": "https://github.com/mambaventures/nzxplorer-mcp-server/issues"
  },
  "author": "Mamba Ventures <api@nzxplorer.co.nz>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
